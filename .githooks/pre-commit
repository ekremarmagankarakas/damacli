#!/usr/bin/env bash
# Aborts commit if any staged C/C++ source is mis-formatted.
# Run `make format` to fix, then re-stage and re-commit.
set -euo pipefail

if ! command -v clang-format >/dev/null 2>&1; then
  echo "pre-commit: clang-format not found, skipping format check" >&2
  exit 0
fi

files=$(git diff --cached --name-only --diff-filter=ACMR \
        -- 'src/*.cc' 'src/*.h' 'src/**/*.cc' 'src/**/*.h' || true)

if [ -z "$files" ]; then
  exit 0
fi

bad=()
while IFS= read -r f; do
  [ -z "$f" ] && continue
  if ! diff -q <(clang-format "$f") "$f" >/dev/null 2>&1; then
    bad+=("$f")
  fi
done <<< "$files"

if [ "${#bad[@]}" -gt 0 ]; then
  echo "pre-commit: formatting issues in:" >&2
  printf '  %s\n' "${bad[@]}" >&2
  echo "Run: make format" >&2
  exit 1
fi
